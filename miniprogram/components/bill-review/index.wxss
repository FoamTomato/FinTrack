.container {
  padding: 20rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== 通用卡片 ========== */
.fui-card {
  width: 92%;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.fui-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding-left: 16rpx;
  border-left: 6rpx solid #07c160;
  margin-bottom: 24rpx;
}

/* ========== 状态卡片（识别中 / 失败 / 空） ========== */
.state-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 80rpx;
}

.state-card {
  width: 92%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.loader-ring {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 6rpx solid #f1f3f5;
  border-top-color: #07c160;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}

.state-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.state-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.state-btn {
  width: 280rpx;
  height: 80rpx;
  background: #f1f3f5;
  color: #333;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.state-btn:active { opacity: 0.8; }

/* ========== 全选 / 统计卡片 ========== */
.summary-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.summary-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.summary-right {
  display: flex;
  align-items: baseline;
}

.summary-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #07c160;
  font-family: 'DIN Alternate', sans-serif;
}

.summary-tip {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

/* ========== 自定义复选框 ========== */
.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
  box-sizing: border-box;
}

.checkbox.checked {
  background-color: #07c160;
  border-color: #07c160;
}

.checkbox.checked::after {
  content: '';
  width: 18rpx;
  height: 10rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg) translateY(-2rpx);
}

/* ========== 账单列表 ========== */
.list-card {
  padding-bottom: 10rpx;
}

.bill-list {
  display: flex;
  flex-direction: column;
}

.bill-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8f9fa;
}

.bill-row:last-child { border-bottom: none; }
.bill-row:active { opacity: 0.7; }

.bill-check {
  flex-shrink: 0;
  padding: 10rpx;
  margin: -10rpx;
}

.bill-icon {
  width: 72rpx;
  height: 72rpx;
  background-color: #f7f8fa;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

/* 识图裁剪小图缩略：与 emoji 图标同尺寸，点按可放大预览 */
.bill-crop {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f7f8fa;
}

.bill-info {
  flex: 1;
  min-width: 0;
}

.bill-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.bill-category {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.bill-badge {
  font-size: 20rpx;
  color: #fa8c16;
  background: #fff7e6;
  border: 1rpx solid #ffe7ba;
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
  line-height: 1.4;
  flex-shrink: 0;
}

/* 已退款徽标：灰显，区别于待核对的橙色 */
.bill-badge.refunded {
  color: #999;
  background: #f2f3f5;
  border-color: #e4e6eb;
}

/* 已退款整行淡化，暗示默认不计入 */
.bill-row.refunded .bill-category,
.bill-row.refunded .bill-amount {
  color: #bbb;
}
.bill-row.refunded .bill-icon {
  opacity: 0.5;
}

.bill-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.bill-date {
  font-family: 'DIN Alternate', sans-serif;
}

.bill-note {
  color: #bbb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.bill-amount {
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.bill-amount.expense { color: #333333; }
.bill-amount.income { color: #ff4d4f; }

/* 异常金额：醒目橙红 + ⚠ 标记，提示用户复核 */
.bill-amount.warn { color: #fa541c; }

.warn-mark {
  font-size: 24rpx;
  margin-right: 4rpx;
}

/* ========== 底部固定按钮 ========== */
.footer-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 4% 40rpx;
  background: linear-gradient(to top, #f7f8fa 60%, rgba(247, 248, 250, 0));
  z-index: 10;
}

.submit-btn-premium {
  width: 100% !important;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #38df86 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(7, 193, 96, 0.25);
  letter-spacing: 1rpx;
  border: none;
}

.submit-btn-premium[disabled] {
  background: #d9d9d9;
  color: #fff;
  box-shadow: none;
}

.submit-btn-premium:active {
  transform: scale(0.99);
  opacity: 0.95;
}
