page {
  background-color: #f7f8fa;
}

.container {
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeIn 0.6s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 类型切换栏 (与首页统一) */
.type-tab-bar {
  width: 92%;
  height: 88rpx;
  background-color: #f1f3f5;
  border-radius: 44rpx;
  display: flex;
  padding: 8rpx;
  box-sizing: border-box;
  margin: 0 auto 40rpx;
}

.tab-item {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 40rpx;
}

.tab-item.active {
  background-color: #ffffff;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tab-item.active.expense { color: #07c160; }
.tab-item.active.income { color: #ff4d4f; }

/* 卡片样式 */
.fui-card {
  width: 92%;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx 40rpx;
  box-sizing: border-box;
  margin: 0 auto 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.02);
}

/* 金额输入特化 */
.main-amount {
  display: flex;
  align-items: baseline;
  padding: 20rpx 0;
}

.currency {
  font-size: 52rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.main-amount input {
  font-size: 80rpx;
  height: 100rpx;
  font-weight: bold;
  font-family: 'DIN Alternate', sans-serif;
  color: #333;
}

.placeholder-amount {
  color: #ebedf0;
}

/* 详情行样式 */
.input-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 100rpx;
}

.border-bottom {
  border-bottom: 1rpx solid #f8f9fa;
}

.label-box {
  display: flex;
  align-items: center;
}

.icon-emoji {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.label {
  font-size: 30rpx;
  color: #666;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.note-input {
  text-align: right;
  font-size: 30rpx;
  color: #333;
  flex: 1;
  margin-left: 40rpx;
}

.placeholder-note {
  color: #ccc;
  font-weight: normal;
}

/* 箭头 */
.nav-arrow {
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid #ccc;
  border-left: 3rpx solid #ccc;
  margin-left: 16rpx;
}

.nav-arrow.right { transform: rotate(135deg); }

/* 底部按钮 */
.footer-action {
  width: 100%;
  padding: 40rpx 0;
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.submit-btn-premium {
  width: 92% !important;
  height: 100rpx;
  background: linear-gradient(135deg, #07c160 0%, #38df86 100%);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 30rpx rgba(7, 193, 96, 0.3);
  letter-spacing: 2rpx;
  border: none;
}

.submit-btn-premium:active {
  transform: scale(0.98);
  opacity: 0.9;
}
