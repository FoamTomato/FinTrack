page {
  background-color: #f7f8fa;
}

.page {
  min-height: 100vh;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 220rpx 60rpx 0;
  color: #999;
}
.empty .em-ic { font-size: 108rpx; opacity: .5; }
.empty .em-t { font-size: 30rpx; margin-top: 28rpx; color: #666; }
.empty .em-s { font-size: 25rpx; margin-top: 16rpx; line-height: 1.7; white-space: pre-line; }

/* 时间线 */
.timeline {
  height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 30rpx 0;
}
.tl-bottom-pad { height: calc(160rpx + env(safe-area-inset-bottom)); }

.day-sep {
  text-align: center;
  font-size: 23rpx;
  color: #bbb;
  margin: 12rpx 0 28rpx;
  position: relative;
}
.day-sep text {
  background: #f7f8fa;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}
.day-sep::before {
  content: '';
  position: absolute;
  left: 60rpx; right: 60rpx; top: 50%;
  height: 1rpx; background: #e8ebef;
}

.tl-item { display: flex; gap: 18rpx; margin-bottom: 28rpx; }
.tl-rail { width: 60rpx; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; }
.tl-badge {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: #fff; flex-shrink: 0;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, .12);
}
.tl-badge.manual { background: linear-gradient(135deg, #5b8def, #7aa6f5); }
.tl-badge.voice { background: linear-gradient(135deg, #07c160, #38df86); }
.tl-badge.scan { background: linear-gradient(135deg, #fa8c16, #ffb454); }

.tl-body { flex: 1; min-width: 0; }
.tl-time { font-size: 22rpx; color: #bbb; margin: 4rpx 0 10rpx; }

.card {
  background: #fff; border-radius: 24rpx;
  padding: 24rpx 26rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, .04);
}

/* 手动卡 */
.c-manual { display: flex; align-items: center; gap: 22rpx; }
.c-manual .cat-ic {
  width: 84rpx; height: 84rpx; border-radius: 26rpx; background: #f3f5f7;
  display: flex; align-items: center; justify-content: center; font-size: 40rpx; flex-shrink: 0;
}
.c-manual .cat-ic .cat-img { width: 52rpx; height: 52rpx; }
.c-manual .mid { flex: 1; min-width: 0; }
.c-manual .mid .cat { font-size: 30rpx; font-weight: 600; color: #333; }
.c-manual .mid .note {
  font-size: 24rpx; color: #999; margin-top: 4rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.amt { font-family: 'DIN Alternate'; font-weight: 700; font-size: 36rpx; flex-shrink: 0; }
.amt.exp { color: #333; }
.amt.inc { color: #ff4d4f; }

/* 语音卡 */
.c-voice .v-quote {
  display: flex; gap: 14rpx; align-items: flex-start;
  background: #f5faf6; border-radius: 18rpx; padding: 16rpx 20rpx; margin-bottom: 18rpx;
}
.c-voice .v-quote .wave { color: #07c160; font-size: 28rpx; }
.c-voice .v-quote .txt { font-size: 26rpx; color: #3a4a3f; line-height: 1.5; flex: 1; }
.mini-list { display: flex; flex-direction: column; gap: 14rpx; }
.mini-row { display: flex; align-items: center; gap: 16rpx; }
.mini-row .dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #07c160; flex-shrink: 0; }
.mini-row .mc {
  font-size: 26rpx; color: #666; flex: 1;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.mini-row .ma { font-family: 'DIN Alternate'; font-weight: 600; font-size: 28rpx; color: #333; }

.card-foot {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 20rpx; padding-top: 18rpx; border-top: 1rpx solid #f0f2f5;
}
.pill { font-size: 22rpx; padding: 5rpx 16rpx; border-radius: 30rpx; font-weight: 600; }
.pill.done { background: #e7f7ee; color: #07c160; }
.pill.wait { background: #fff3e6; color: #fa8c16; }
.pill.proc { background: #eef4ff; color: #1890ff; }
.pill.fail { background: #fdecec; color: #ff4d4f; }
.card-foot .sum { font-size: 24rpx; color: #999; }
.card-foot .sum .b { font-family: 'DIN Alternate'; color: #333; font-size: 28rpx; }

/* 图片批次卡 */
.c-scan .grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin-bottom: 18rpx;
}
.c-scan .grid .ph {
  position: relative; width: 100%; padding-bottom: 100%; border-radius: 16rpx; overflow: hidden;
  background: linear-gradient(135deg, #e9edf1, #dde3e9);
}
.c-scan .grid .ph .ph-img { position: absolute; inset: 0; width: 100%; height: 100%; }
.c-scan .grid .ph .ph-ph {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; color: #aab3bd;
}
.c-scan .grid .ph.recognized::after {
  content: '✓'; position: absolute; right: 6rpx; bottom: 6rpx;
  width: 30rpx; height: 30rpx; border-radius: 50%; background: #07c160; color: #fff;
  font-size: 20rpx; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, .3);
}
.c-scan .grid .ph .badge-n {
  position: absolute; left: 6rpx; top: 6rpx;
  background: rgba(0, 0, 0, .5); color: #fff; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 16rpx;
}
.c-scan .grid .ph.more {
  padding-bottom: 0;
  aspect-ratio: 1 / 1;
  background: rgba(0, 0, 0, .55); color: #fff; font-size: 30rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

/* ============ 半屏 Sheet ============ */
.sheet-scrim {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0, 0, 0, .45);
  display: flex; flex-direction: column; justify-content: flex-end;
}
.sheet {
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  /* 底部多留 100rpx 给永远置顶的自定义 tabBar，否则 sheet 底部按钮(识别记账/保存)会被挡 */
  padding: 12rpx 0 calc(140rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, .12);
  animation: sheetUp .28s cubic-bezier(.25, 1, .5, 1);
}
/* 手动表单内容多，给个更高的最小高度，避免局促 */
.sheet.manual-sheet { min-height: 76vh; }
/* 图片 sheet 内容少，但也给足高度，不要太矮 */
.sheet.scan-sheet { min-height: 42vh; }
.sheet.voice-sheet { min-height: 58vh; }
@keyframes sheetUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.sheet .grip { width: 72rpx; height: 8rpx; border-radius: 6rpx; background: #e2e5e9; margin: 12rpx auto 6rpx; }
.sheet .sh-head { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 36rpx 6rpx; }
.sheet .sh-title { font-size: 32rpx; font-weight: 700; }
.sheet .sh-close { font-size: 38rpx; color: #999; padding: 0 8rpx; }

/* 语音 sheet */
.voice-sheet-body { padding: 30rpx 40rpx 12rpx; text-align: center; }
.vs-text {
  background: #f5faf6; border-radius: 20rpx; min-height: 120rpx;
  padding: 22rpx 26rpx; font-size: 28rpx; color: #3a4a3f; text-align: left;
  margin-bottom: 44rpx; line-height: 1.6;
}
.vs-text.empty { color: #b6c2ba; }
.vs-mic {
  width: 200rpx; height: 200rpx; border-radius: 50%; margin: 0 auto 20rpx;
  background: linear-gradient(135deg, #07c160, #38df86);
  display: flex; align-items: center; justify-content: center;
  font-size: 84rpx; color: #fff; box-shadow: 0 14rpx 32rpx rgba(7, 193, 96, .35);
}
.vs-mic.rec { animation: micPulse 1.3s ease-in-out infinite; }
@keyframes micPulse {
  0%, 100% { box-shadow: 0 0 0 14rpx rgba(7, 193, 96, .18), 0 14rpx 32rpx rgba(7, 193, 96, .4); }
  50% { box-shadow: 0 0 0 28rpx rgba(7, 193, 96, .08), 0 14rpx 32rpx rgba(7, 193, 96, .4); }
}
.vs-state { font-size: 26rpx; color: #666; margin-bottom: 28rpx; }
.submit-btn {
  width: 88%; height: 96rpx; line-height: 96rpx; margin: 0 auto;
  padding: 0; text-align: center;
  background: linear-gradient(135deg, #07c160, #38df86); color: #fff;
  border-radius: 48rpx; font-size: 32rpx; font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(7, 193, 96, .3);
}
.submit-btn.ghost { background: #f1f3f5; color: #bbb; box-shadow: none; }
.submit-btn::after { border: none; }

/* 图片 sheet */
.scan-sheet-body { padding: 40rpx 40rpx 12rpx; }
.scan-pick {
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20rpx;
  background: linear-gradient(135deg, #07c160, #38df86);
  border-radius: 28rpx; padding: 64rpx 32rpx; color: #fff;
  box-shadow: 0 10rpx 26rpx rgba(7, 193, 96, .26);
}
.scan-pick:active { transform: scale(.985); }
.scan-cam {
  width: 132rpx; height: 132rpx; border-radius: 36rpx;
  background: rgba(255, 255, 255, .22);
  display: flex; align-items: center; justify-content: center; font-size: 68rpx; flex-shrink: 0;
}
.scan-pick-txt { text-align: center; }
.scan-pick-t { font-size: 34rpx; font-weight: 700; }
.scan-pick-s { font-size: 25rpx; opacity: .9; margin-top: 10rpx; }
.scan-tip { text-align: center; font-size: 24rpx; color: #999; margin-top: 28rpx; }
