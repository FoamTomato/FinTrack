<view class="container">
  <!-- 页面顶部背景 -->
  <view class="page-top-bg"></view>

  <view class="tab-header">
    <view class="tab-item {{currentType === 2 ? 'active' : ''}}" bindtap="onSwitchType" data-type="2">支出</view>
    <view class="tab-item {{currentType === 1 ? 'active' : ''}}" bindtap="onSwitchType" data-type="1">收入</view>
  </view>

  <view class="category-list">
    <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="onGoToDetail" data-item="{{item}}" hover-class="item-hover">
      <view class="item-left">
        <view class="item-icon">{{item.icon}}</view>
        <text class="item-name">{{item.name}}</text>
      </view>
      <view class="item-right">
        <!-- 系统默认分类 -->
        <block wx:if="{{item.is_default == 1}}">
          <view class="system-tag">系统</view>
        </block>
        <!-- 自定义分类 -->
        <block wx:else>
          <text class="edit-link" catchtap="onStartEdit" data-item="{{item}}">编辑</text>
          <view class="delete-btn" catchtap="onDeleteCategory" data-id="{{item.id}}">删除</view>
        </block>
      </view>
    </view>
    
    <!-- 添加按钮 placeholder (防止遮挡) -->
    <view style="height: 120rpx;"></view>
  </view>

  <!-- 添加按钮 (Fixed) -->
  <view class="add-btn-wrapper" bindtap="onShowAddModal">
    <view class="add-icon">+</view>
    <text>添加分类</text>
  </view>

  <!-- 添加/编辑分类弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}">
    <view class="modal-content">
      <view class="modal-title">{{editingId ? '编辑分类' : '新建分类'}}</view>
      <view class="input-form">
        <view class="input-row">
          <text class="input-label">名称</text>
          <input class="modal-input" placeholder="输入分类名称 (如: 奶茶)" bindinput="onInputName" value="{{newCategoryName}}"/>
        </view>
        <view class="input-row">
          <text class="input-label">图标</text>
          <input class="modal-input" placeholder="输入图标Emoji (如: 🥤)" bindinput="onInputIcon" value="{{newCategoryIcon}}"/>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn cancel" bindtap="onHideModal">取消</button>
        <button class="btn confirm" bindtap="handleConfirm">{{editingId ? '保存' : '确定'}}</button>
      </view>
    </view>
  </view>
</view>
