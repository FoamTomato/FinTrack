page {
  background-color: #f7f8fa;
  padding-bottom: 60rpx;
}

.container {
  padding: 20rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeIn 0.6s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 通用卡片（与首页 .fui-card 一致） ========== */
.fui-card {
  width: 92%;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.fui-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding-left: 16rpx;
  border-left: 6rpx solid #07c160;
}

/* ========== 上传卡片 ========== */
.upload-card {
  background: linear-gradient(135deg, #07c160 0%, #38df86 100%);
  padding: 56rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(7, 193, 96, 0.2);
  transition: all 0.2s ease;
}

.upload-card.uploading {
  opacity: 0.92;
}

.upload-card:active {
  transform: scale(0.99);
  opacity: 0.92;
}

.upload-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ffffff;
}

.upload-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.upload-icon {
  width: 72rpx;
  height: 72rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 扁平相机：机身 + 顶部取景器凸起 + 中央镜头 */
.cam-body {
  width: 72rpx;
  height: 52rpx;
  background: #ffffff;
  border-radius: 10rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cam-body::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 18rpx;
  width: 22rpx;
  height: 12rpx;
  background: #ffffff;
  border-radius: 4rpx 4rpx 0 0;
}

.cam-body::after {
  content: '';
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 6rpx;
  height: 6rpx;
  background: #6b9aff;
  border-radius: 50%;
}

.cam-lens {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: transparent;
  border: 4rpx solid #6b9aff;
  box-sizing: border-box;
}

.upload-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  text-align: center;
}

.upload-sub {
  font-size: 24rpx;
  opacity: 0.9;
  text-align: center;
}

/* ========== 历史卡片 ========== */
.history-card {
  padding: 30rpx 30rpx 10rpx;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.refresh-btn {
  font-size: 36rpx;
  color: #999;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f7f8fa;
}

.refresh-btn:active {
  background: #ececec;
}

.refresh-btn.spinning {
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  padding: 60rpx 0;
}

.task-list {
  display: flex;
  flex-direction: column;
}

.task-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8f9fa;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item:active {
  opacity: 0.7;
}

/* 缩略图 */
.task-thumb-wrap {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f7f8fa;
}

.task-thumb {
  width: 88rpx;
  height: 88rpx;
  display: block;
}

.task-thumb-placeholder {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.task-status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 状态标签 */
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-weight: 500;
}

.status-tag.processing {
  background: #fff7e6;
  color: #fa8c16;
}

.status-tag.completed {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.status-tag.failed {
  background: #fff1f0;
  color: #ff4d4f;
}

.mini-spin {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #ffe7ba;
  border-top-color: #fa8c16;
  animation: spin 0.7s linear infinite;
  flex-shrink: 0;
}

.item-count {
  font-size: 24rpx;
  color: #666;
}

/* 右侧 */
.task-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.tag-imported {
  font-size: 22rpx;
  color: #999;
  background: #f1f3f5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.action-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
  line-height: 1;
}

.action-arrow.failed {
  color: #ffa39e;
}
