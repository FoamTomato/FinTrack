<wxs module="utils">
  var getGroupName = function(groups, id) {
    if (!groups || !id) return '小组账本';
    for (var i = 0; i < groups.length; i++) {
        if (groups[i].id === id) return groups[i].name;
    }
    return '小组账本';
  }
  module.exports = {
    getGroupName: getGroupName
  };
</wxs>
<view class="container">

  <!-- 核心资产概览卡片 (极简高级感) -->
  <view class="summary-card">
    <view class="bill-switch-btn" bindtap="showBillTypeSwitch">
      <view class="switch-icon">⇄</view>
        <text class="switch-text">{{billType === 1 ? utils.getGroupName(myGroups, currentGroupId) : '个人账本'}}</text>
    </view>
    <view class="summary-main">
      <text class="summary-label">本月结余</text>
      <text class="summary-value">{{summary.balance}}</text>
    </view>
    <view class="summary-sub">
      <view class="summary-item">
        <text class="sub-label">本月收入</text>
        <text class="sub-value income">+{{summary.totalIncome}}</text>
      </view>
      <view class="summary-item">
        <text class="sub-label">本月支出</text>
        <text class="sub-value expense">-{{summary.totalExpense}}</text>
      </view>
    </view>
  </view>

  <!-- 统计分析卡片：饼图 + 大类占比 -->
  <view class="fui-card">
    <view class="fui-card-title">{{typeFilter == 1 ? '收入构成' : '支出构成'}}</view>
    <view class="fui-card-content">
      <view class="analysis-overview" wx:if="{{analysisList.length > 0}}">
        <!-- 环形饼图 -->
        <view class="pie-wrap" style="background: {{pieStyle}}">
          <view class="pie-hole">
            <text class="pie-total-label">{{typeFilter == 1 ? '收入' : '支出'}}</text>
            <text class="pie-total">¥{{analysisTotal}}</text>
          </view>
        </view>
        <!-- 图例（前 4 大类占比） -->
        <view class="pie-legend">
          <view class="legend-item" wx:for="{{pieLegend}}" wx:key="name">
            <view class="dot" style="background: {{item.color}}"></view>
            <text class="name">{{item.name}}</text>
            <text class="pct">{{item.percent}}%</text>
          </view>
        </view>
      </view>

      <!-- 前 6 大类柱状图 -->
      <view class="bar-chart" wx:if="{{barChartData.length > 0}}">
        <view class="bar-item" wx:for="{{barChartData}}" wx:key="name">
          <text class="bar-value">{{item.displayAmount}}</text>
          <view class="bar-column-wrapper">
            <view class="bar-column" style="height: {{item.heightPercent}}%; background: {{item.color}}"></view>
          </view>
          <text class="bar-label">{{item.displayName}}</text>
        </view>
      </view>

      <view class="analysis-empty" wx:if="{{!loading && analysisList.length === 0}}">该时间段内暂无记录</view>
    </view>
  </view>

  <!-- 分类明细卡片：大类占比 + 点击展开小类 -->
  <view class="fui-card" wx:if="{{analysisList.length > 0}}">
    <view class="fui-card-title">分类明细</view>
    <view class="fui-card-content">
      <view class="category-row {{item.expanded ? 'expanded' : ''}}"
            wx:for="{{analysisList}}" wx:key="name">
        <view class="row-main" bindtap="onToggleSub" data-index="{{index}}">
          <view class="cat-icon">
            <image wx:if="{{item.iconUrl}}" class="cat-icon-img" src="{{item.iconUrl}}" mode="aspectFit"></image>
            <text wx:else>{{item.icon || '🏷️'}}</text>
          </view>
          <view class="cat-body">
            <view class="body-top">
              <text class="cat-name">{{item.name}}</text>
              <text class="cat-amount">¥{{item.amount}}</text>
            </view>
            <view class="body-bottom">
              <view class="progress-bar">
                <view class="progress-fill" style="width:{{item.percent}}%; background: {{item.color}}"></view>
              </view>
              <text class="cat-pct">{{item.percent}}%</text>
            </view>
          </view>
          <view class="expand-icon {{item.expanded ? 'up' : ''}}"></view>
        </view>

        <!-- 子分类展开 -->
        <view class="sub-list" wx:if="{{item.expanded}}">
          <view class="sub-item" wx:for="{{item.items}}" wx:key="name" wx:for-item="sub">
            <view class="sub-line"></view>
            <text class="sub-name">{{sub.name}}</text>
            <text class="sub-amount">¥{{sub.amount}}</text>
            <text class="sub-pct">{{sub.percent}}%</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 月度收支日历 -->
  <view class="fui-card">
    <view class="fui-card-title-row">
      <view class="fui-card-title-text">月度收支日历</view>
      <view class="card-filter-tabs">
        <view class="card-filter-item {{typeFilter == 0 ? 'active' : ''}}" bindtap="onTypeChange" data-type="0">全部</view>
        <view class="card-filter-item {{typeFilter == 2 ? 'active' : ''}}" bindtap="onTypeChange" data-type="2">支出</view>
        <view class="card-filter-item {{typeFilter == 1 ? 'active' : ''}}" bindtap="onTypeChange" data-type="1">收入</view>
      </view>
    </view>
    <view class="fui-card-content">
      <!-- 日历头部导航 -->
      <view class="calendar-nav">
        <view class="nav-btn" bindtap="changeMonth" data-delta="-1">
          <view class="nav-arrow left"></view>
        </view>
        <view class="nav-title">{{currentYear}}年 {{currentMonth}}月</view>
        <view class="nav-right-box">
          <view class="nav-today" bindtap="goToday">今</view>
          <view class="nav-btn" bindtap="changeMonth" data-delta="1">
            <view class="nav-arrow right"></view>
          </view>
        </view>
      </view>
      
      <!-- 星期轴 -->
      <view class="calendar-header">
        <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</text>
      </view>

      <!-- 日历网格 (直接展示，配合动画) -->
      <view class="calendar-grid {{!loading ? 'fade-in' : ''}}" style="opacity: 0;">
        <block wx:for="{{calendarData}}" wx:key="index">
          <view wx:if="{{item.empty}}" class="calendar-cell empty" style="animation-delay: {{index * 0.02}}s"></view>
          <view wx:else 
                class="calendar-cell {{item.type}} {{item.isToday ? 'is-today' : ''}}"
                bindtap="showCalendarDetail" 
                data-item="{{item}}"
                style="animation-delay: {{index * 0.02}}s">
            <text class="day-label">{{item.isToday ? '今' : item.day}}</text>
            <text class="amount-label">{{item.hasData ? item.amountStr : '0.00'}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 明细列表卡片 (扁平化：每张卡片显示完整年月日时分) -->
  <view class="fui-card">
    <view class="fui-card-title">近期明细</view>
    <view class="fui-card-content">
      <view class="fui-list">
        <block wx:for="{{transactions}}" wx:key="id">
          <movable-area class="list-row-area">
              <movable-view class="list-row-content"
                          direction="horizontal"
                          damping="40"
                          x="{{item.x}}"
                          data-index="{{index}}"
                          data-id="{{item.id}}"
                          bindchange="onSwipeChange"
                          bindtouchstart="onSwipeStart"
                          bindtouchend="onSwipeEnd"
                          bindtap="onEditTransaction"
                          style="width: calc(100% + 150rpx); display: flex;">

                <view class="fui-list-cell" style="flex: 1; padding-left: 20rpx;">
                  <view class="cell-icon">
                    <image wx:if="{{item.iconUrl}}" class="cell-icon-img" src="{{item.iconUrl}}" mode="aspectFit"></image>
                    <text wx:else>{{item.icon}}</text>
                  </view>
                  <view class="cell-info">
                    <view class="cell-category">
                      {{item.category}}
                      <!-- 小组账本显示创建人 -->
                      <image wx:if="{{item.creatorAvatar}}" class="creator-avatar" src="{{item.creatorAvatar}}" mode="aspectFill"></image>
                      <text wx:elif="{{item.creatorName}}" class="creator-name">{{item.creatorName}}</text>
                    </view>
                    <text class="cell-time">{{item.note || '无备注'}}</text>
                  </view>
                  <view class="cell-right-box" style="margin-right: 30rpx;">
                    <view class="cell-amount {{item.type === 1 ? 'income' : 'expense'}}">
                      {{item.type === 1 ? '+' : '-'}}{{item.amount}}
                    </view>
                    <view class="cell-full-time">{{item.displayDateTime}}</view>
                  </view>
                </view>

                <!-- 红色按钮放在 movable-view 内部末尾 -->
                <view class="delete-btn" catchtap="onDeleteTransaction" data-id="{{item.id}}">删除</view>
              </movable-view>
          </movable-area>
        </block>
      </view>
      <view class="empty-tip" wx:if="{{!transactions.length && !loading}}">暂无记录</view>
      <view class="empty-tip" wx:if="{{loading}}">加载中...</view>
    </view>
  </view>
  <!-- 日历详情弹窗 (自定义高级弹窗) -->
  <view class="base-modal {{showDetailPopup ? 'show' : ''}}" bindtap="closeDetailPopup">
    <view class="detail-modal" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">{{detailDate}} 全天明细</text>
        <view class="close-icon" bindtap="closeDetailPopup">×</view>
      </view>
      <scroll-view scroll-y class="modal-body">
        <view class="detail-list" wx:if="{{selectedDateTransactions.length}}">
          <view class="fui-list-cell" wx:for="{{selectedDateTransactions}}" wx:key="id">
            <view class="cell-icon">
                      <image wx:if="{{item.iconUrl}}" class="cell-icon-img" src="{{item.iconUrl}}" mode="aspectFit"></image>
                      <text wx:else>{{item.icon}}</text>
                    </view>
            <view class="cell-info">
              <view class="cell-category">
                {{item.category}}
                <image wx:if="{{item.creatorAvatar}}" class="creator-avatar" src="{{item.creatorAvatar}}" mode="aspectFill"></image>
                <text wx:elif="{{item.creatorName}}" class="creator-name">{{item.creatorName}}</text>
              </view>
              <text class="cell-time">{{item.note || '无备注'}}</text>
            </view>
            <view class="cell-right-box">
              <view class="cell-amount {{item.type === 1 ? 'income' : 'expense'}}">
                {{item.type === 1 ? '+' : '-'}}{{item.amount}}
              </view>
              <view class="cell-full-time">{{item.dayTime}}</view>
            </view>
          </view>
        </view>
        <view class="empty-tip" style="padding: 100rpx 0" wx:else>当日暂无记账数据</view>
      </scroll-view>
      <view class="modal-footer">
        <button class="fui-btn-primary" bindtap="closeDetailPopup">我知道了</button>
      </view>
    </view>
  </view>
  
  <!-- 账本切换弹窗 -->
  <view class="base-modal {{showBillTypeModal ? 'show' : ''}}" bindtap="closeBillTypeModal">
    <view class="bill-type-sheet" catchtap="noop">
      <view class="sheet-header">切换账本类型</view>
      <view class="sheet-options">
        <!-- 个人账本 -->
        <view class="sheet-item {{billType === 0 ? 'active' : ''}}" bindtap="onSwitchBillType" data-type="0">
          <text class="item-icon">👤</text>
          <text class="item-name">个人账本</text>
          <text class="item-check" wx:if="{{billType === 0}}">✓</text>
        </view>
        
        <view class="sheet-divider">我的小组</view>

        <!-- 小组列表循环 -->
        <block wx:if="{{myGroups.length > 0}}">
          <view class="sheet-item {{billType === 1 && currentGroupId === item.id ? 'active' : ''}}" 
                wx:for="{{myGroups}}" 
                wx:key="id"
                bindtap="onSwitchBillType" 
                data-type="1" 
                data-groupid="{{item.id}}">
            <text class="item-icon">👥</text>
            <text class="item-name">{{item.name}}</text>
            <text class="item-check" wx:if="{{billType === 1 && currentGroupId === item.id}}">✓</text>
          </view>
        </block>
        <block wx:else>
           <view class="sheet-empty-tip" bindtap="navToSettings" data-url="/pages/group/index">暂无小组，去创建或加入 ></view>
        </block>
      </view>
    </view>
  </view>
</view>
