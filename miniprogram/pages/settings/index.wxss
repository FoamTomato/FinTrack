/* pages/settings/index.wxss */
page {
  background-color: #f7f8fa;
}

.container {
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 通用卡片样式 */
.fui-card {
  width: 92%;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 0; /* 内部用 item padding */
  box-sizing: border-box;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.02);
  overflow: hidden;
}

/* 用户卡片特化 */
.user-card {
  padding: 40rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffffff 0%, #fefefe 100%);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #eee;
  margin-right: 30rpx;
  /* 占位图效果 */
  background-image: url('https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwBHcaS5u2otR7aaVfc8jK58H20d20N0d20N0d20N0/0'); 
  background-size: cover;
}

.user-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.required-tag {
  font-size: 20rpx;
  color: #fff;
  background-color: #ff4d4f;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  font-weight: bold;
}

.user-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* 设置分组 */
.group-title {
  font-size: 26rpx;
  color: #999;
  margin: 10rpx 0 20rpx 50rpx; /* 对齐卡片内容的视觉起点 */
  width: 90%;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid #f9f9f9;
  transition: background-color 0.2s;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background-color: #f9f9f9;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  width: 40rpx;
  text-align: center;
}

.item-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 26rpx;
  color: #bbb;
  margin-right: 16rpx;
}

/* 箭头 */
.nav-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #e0e0e0;
  border-right: 4rpx solid #e0e0e0;
  transform: rotate(45deg);
}

.version-info {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #ddd;
  text-align: center;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(8rpx);
}

.modal-content {
  width: 80%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  animation: modalScale 0.3s ease-out;
}

@keyframes modalScale {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-body-form {
  margin-bottom: 40rpx;
}

.input-group-row {
  display: flex;
  align-items: center;
  background-color: #f7f8fa;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.input-group-row .label {
  font-size: 28rpx;
  color: #666;
  width: 100rpx;
}

.modal-input-field {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.modal-tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
}

.btn-action {
  width: 46% !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
  margin: 0 !important;
}

.btn-action.cancel {
  background-color: #f5f5f5;
  color: #666;
  border: none;
}

.btn-action.confirm {
  background: linear-gradient(135deg, #07c160 0%, #38df86 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.2);
}
/* 头像选择样式 */
.avatar-selection-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 160rpx !important;
  height: 160rpx !important;
  border-radius: 50% !important;
  background-color: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
  overflow: visible !important;
  border: none !important;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  background: #07c160;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.avatar-hint {
  font-size: 24rpx;
  color: #999;
}

.btn-action.confirm.full-width {
  width: 100% !important;
}
