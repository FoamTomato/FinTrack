/* pages/login/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #07C160 0%, #06AD56 30%, #f5f5f5 30%);
  display: flex;
  flex-direction: column;
}

/* ===== 授权信息填写页 ===== */
.setup-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.setup-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.setup-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.setup-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-btn {
  width: 180rpx;
  height: 180rpx;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.avatar-plus {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1;
}

.avatar-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 昵称输入 */
.input-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 40rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.input-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.input-wrap {
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  font-size: 34rpx;
  color: #333;
  background: transparent;
}

.input-placeholder {
  color: #ccc;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #cccccc;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s;
  margin-top: auto;
  margin-bottom: 48rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.active {
  background: #07C160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}
