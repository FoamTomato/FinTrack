<view class="container">

  <!-- 授权信息填写页 -->
  <view class="setup-page">
    <view class="setup-header">
      <text class="setup-title">完善个人信息</text>
      <text class="setup-sub">选择头像和填写昵称，开始你的记账之旅</text>
    </view>

    <!-- 头像选择 -->
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="avatar-wrap">
          <image
            wx:if="{{avatarUrl}}"
            class="avatar-img"
            src="{{avatarUrl}}"
            mode="aspectFill"
          />
          <view wx:else class="avatar-placeholder">
            <text class="avatar-plus">+</text>
          </view>
        </view>
      </button>
      <text class="avatar-tip">点击选择微信头像</text>
    </view>

    <!-- 昵称输入 -->
    <view class="input-section">
      <view class="input-label">我的昵称</view>
      <view class="input-wrap">
        <input
          class="nickname-input"
          type="nickname"
          placeholder="点击填写昵称"
          placeholder-class="input-placeholder"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 提交按钮 -->
    <button
      class="submit-btn {{canSubmit ? 'active' : ''}}"
      disabled="{{!canSubmit || submitting}}"
      bindtap="handleSubmit"
    >
      {{submitting ? '登录中...' : '开始记账'}}
    </button>
  </view>

</view>
