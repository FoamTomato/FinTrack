page { background-color: #f7f8fa; }

.page { padding: 24rpx 30rpx calc(40rpx + env(safe-area-inset-bottom)); }

.hint { font-size: 24rpx; color: #999; margin-bottom: 24rpx; }
.loading, .empty { text-align: center; color: #999; font-size: 28rpx; padding: 120rpx 0; }

.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.cell {
  background: #fff; border-radius: 18rpx; overflow: hidden;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, .04);
}
.cell .thumb { width: 100%; height: 200rpx; display: block; background: #e9edf1; }
.cell-foot { padding: 12rpx 14rpx; }
.cell-foot .st { font-size: 21rpx; font-weight: 600; }
.st.imp { color: #07c160; }
.st.wait { color: #fa8c16; }
.st.proc { color: #1890ff; }
.st.fail { color: #ff4d4f; }
