<view class="page">
  <view class="hint">点击单张图片查看该图识别出的账单及记账状态</view>

  <view wx:if="{{loading}}" class="loading">加载中…</view>

  <view wx:elif="{{photos.length === 0}}" class="empty">未找到该批次图片</view>

  <view wx:else class="grid">
    <view wx:for="{{photos}}" wx:key="taskId" wx:for-item="ph"
      class="cell {{ph.status === 'completed' ? 'done' : ''}}"
      data-taskid="{{ph.taskId}}"
      bindtap="onTapPhoto">
      <image class="thumb" src="{{ph.thumb}}" mode="aspectFill" lazy-load
        data-url="{{ph.thumb}}" catchtap="onPreview"></image>
      <view class="cell-foot">
        <text class="st {{ph.imported ? 'imp' : (ph.status === 'failed' ? 'fail' : (ph.status === 'completed' ? 'wait' : 'proc'))}}">{{ph.statusText}}</text>
      </view>
    </view>
  </view>
</view>
