<view class="container">
  
  <!-- 页面标题与背景装饰 -->
  <view class="page-top-bg"></view>
  <view class="header-section">
    <text class="page-title">小组账本</text>
    <text class="page-subtitle">与家人好友共享消费账目</text>
  </view>

  <!-- 顶部导航切换 (Segmented Control) -->
  <view class="tab-sc">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      <view class="item-text">我的小组</view>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      <view class="item-text">创建 / 加入</view>
    </view>
    <view class="tab-slider" style="left: {{activeTab * 50}}%"></view>
  </view>

  <!-- 内容区域 -->
  <view class="content-body">
    
    <!-- 1. 我的小组列表 -->
    <scroll-view scroll-y class="group-list-box {{activeTab === 0 ? 'show' : ''}}" wx:if="{{activeTab === 0}}">
      <view class="empty-state" wx:if="{{myGroups.length === 0 && !loading}}">
        <view class="empty-icon-box">
          <text class="empty-emoji">👥</text>
        </view>
        <text class="empty-title">暂无小组</text>
        <text class="empty-desc">加入或创建一个小组，开启多人记账模式</text>
        <button class="empty-btn" bindtap="switchTab" data-index="1">立即开启</button>
      </view>

      <view class="group-ultra-card" wx:for="{{myGroups}}" wx:key="id" bindtap="viewMembers" data-group="{{item}}">
        <view class="card-header">
          <view class="group-brand">
            <text class="brand-char">{{item.name[0]}}</text>
          </view>
          <view class="group-main-info">
            <text class="ultra-group-name">{{item.name}}</text>
            <view class="tag-row">
              <text class="ultra-tag {{item.role === 'owner' ? 'owner' : 'member'}}">{{item.role === 'owner' ? '群主' : '成员'}}</text>
              <text class="ultra-tag-member">{{item.member_count}} 人</text>
            </view>
          </view>
          <view class="nav-arrow-pro"></view>
        </view>
        
        <view class="card-footer-info">
          <view class="invite-box" catchtap="copyCode" data-code="{{item.invite_code}}">
            <text class="invite-label">邀请码</text>
            <text class="invite-code">{{item.invite_code}}</text>
            <view class="copy-hint">
              <text class="copy-emoji">📋</text>
              <text>复制</text>
            </view>
          </view>
        </view>
      </view>
      <view class="list-bottom-pad"></view>
    </scroll-view>

    <!-- 2. 创建/加入面板 - 重构为 Portal 门户样式 -->
    <view class="action-view {{activeTab === 1 ? 'show' : ''}}" wx:if="{{activeTab === 1}}">
      
      <view class="action-portal">
        <!-- 创建板块: 强调感 -->
        <view class="portal-card create-portal">
          <view class="portal-badge">NEW</view>
          <view class="portal-main">
            <view class="portal-icon-box">
              <view class="portal-icon-inner">
                <text class="portal-emoji">🎨</text>
              </view>
            </view>
            <view class="portal-info">
              <text class="portal-title">创建新小组</text>
              <text class="portal-desc">建立您的私密或公共共享账本</text>
            </view>
          </view>
          <view class="portal-interaction">
            <input 
              class="portal-input" 
              placeholder="为小组起个名字" 
              bindinput="onInputName" 
              value="{{newGroupName}}"
              placeholder-class="portal-placeholder"
            />
            <button class="portal-go-btn" bindtap="onCreateGroup">立即创建</button>
          </view>
        </view>

        <!-- 极简分隔 -->
        <view class="portal-separator">
          <view class="sep-line"></view>
          <text class="sep-text">OR</text>
          <view class="sep-line"></view>
        </view>

        <!-- 加入板块: 简洁感 -->
        <view class="portal-card join-portal">
          <view class="portal-main">
            <view class="portal-icon-box">
              <view class="portal-icon-inner">
                <text class="portal-emoji">🗝️</text>
              </view>
            </view>
            <view class="portal-info">
              <text class="portal-title">加入小组</text>
              <text class="portal-desc">输入受邀码，与好友合并账单</text>
            </view>
          </view>
          <view class="portal-interaction">
            <input 
              class="portal-input" 
              placeholder="请输入 6 位邀请码" 
              bindinput="onInputCode" 
              value="{{inviteCodeInput}}"
              placeholder-class="portal-placeholder"
            />
            <button class="portal-go-btn secondary" bindtap="onJoinGroup">确认加入</button>
          </view>
        </view>
      </view>

    </view>
  </view>

  <!-- 成员列表弹窗 (Ultra Modal) -->
  <view class="ultra-modal {{showMembersModal ? 'show' : ''}}" wx:if="{{showMembersModal}}" bindtap="closeMembersModal">
    <view class="modal-body" catchtap="stopPop">
      <view class="modal-indicator"></view>
      <view class="modal-head">
        <view class="modal-header-info">
          <text class="modal-title">{{currentGroup.name}}</text>
          <text class="modal-subtitle">共有 {{currentMembers.length}} 位成员</text>
        </view>
        <view class="modal-close-btn" bindtap="closeMembersModal"></view>
      </view>
      
      <scroll-view scroll-y class="member-scroll-view">
        <view class="ultra-member-item" wx:for="{{currentMembers}}" wx:key="id">
          <view class="member-avatar-pro">
             <image class="member-avatar-img" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
             <text wx:if="{{!item.avatarUrl}}">{{item.nickname[0] || 'U'}}</text>
             <view class="owner-badge" wx:if="{{item.role === 'owner'}}">👑</view>
          </view>
          <view class="member-core">
            <text class="member-nickname">{{item.nickname || '微信用户'}}</text>
            <text class="member-join-date">加入于 {{item.joinedDate}}</text>
          </view>
          <view class="member-status-tag {{item.role === 'owner' ? 'is-owner' : ''}}">
            {{item.role === 'owner' ? '群主' : '成员'}}
          </view>
        </view>
        <view class="modal-bottom-safe"></view>
      </scroll-view>
    </view>
  </view>

</view>