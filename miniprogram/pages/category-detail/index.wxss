/* Category Detail - Minimalist & Clean Design */
page {
  background-color: #f6f7f9;
  color: #333;
}

/* 移除之前的渐变背景 */
.premium-bg {
  display: none;
}

.content-wrapper {
  padding: 30rpx 30rpx 200rpx;
}

/* 头部设计：纯白卡片，平实稳重 */
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  background: #ffffff;
  padding: 40rpx;
  border-radius: 20rpx;
  /* 极淡的阴影，几乎不可见，只为了区分层级 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

.parent-info-group {
  display: flex;
  align-items: center;
}

.icon-box {
  width: 90rpx;
  height: 90rpx;
  background: #f0f2f5; /* 浅灰底色，非纯白，增加对比 */
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
}

.text-box {
  display: flex;
  flex-direction: column;
}

.p-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.p-type {
  font-size: 24rpx;
  color: #999;
}

.stats-label {
  font-size: 22rpx;
  color: #666;
  background: #f0f2f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 列表部分 */
.main-list-section {
  width: 100%;
}

.list-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx 20rpx;
}

.l-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
}

.l-count {
  font-size: 24rpx;
  color: #bbb;
}

.list-container {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden; /* 保证子项的分割线不溢出 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

/* 列表项：回归经典的列表样式 */
.list-item-pro {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5; /* 极细分割线 */
  transition: background-color 0.2s;
}

.list-item-pro:last-child {
  border-bottom: none;
}

.list-item-pro:active {
  background-color: #f9f9f9;
}

.item-left {
  display: flex;
  align-items: center;
}

/* 更低调的指示点 */
.dot-indicator {
  width: 8rpx;
  height: 8rpx;
  background: #ddd; /* 默认灰色 */
  border-radius: 50%;
  margin-right: 24rpx;
}

/* 只有选中或激活时才用绿色，但这只是展示，用实心圆点即可 */
.list-item-pro .name {
  font-size: 30rpx;
  color: #333;
  font-weight: 400; /* 不加粗，更清爽 */
}

.item-right {
  display: flex;
  align-items: center;
}

.use-count {
  font-size: 22rpx;
  color: #ccc;
  margin-right: 20rpx;
  display: none; /* 简洁模式下隐藏这个不太重要的信息 */
}

.del-circle {
  width: 44rpx;
  height: 44rpx;
  /* 去掉红色背景，改为简单的灰色图标，减少视觉干扰 */
  background: transparent; 
  color: #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 50%;
}

.del-circle:active {
  background: #f0f0f0;
  color: #999;
}

/* 底部输入框：实体悬浮 */
.float-input-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  z-index: 100;
  background: transparent; /* 透出背景 */
}

.glass-capsule {
  background: #ffffff; /* 纯白实体 */
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  padding: 0 10rpx 0 40rpx;
  /* 柔和的实体投影，产生悬浮感 */
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08); 
  border: none;
}

.capsule-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #333;
}

.ph-style {
  color: #ccc;
}

.capsule-btn {
  width: 140rpx;
  height: 80rpx;
  background: #333; /* 黑色按钮，极致简洁 */
  color: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  transition: opacity 0.2s;
}

.capsule-btn:active {
  opacity: 0.8;
}

/* 空状态 */
.empty-placeholder {
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  filter: grayscale(100%); /* 灰色图标 */
  opacity: 0.3;
}

.empty-placeholder text {
  font-size: 26rpx;
  color: #ccc;
}
