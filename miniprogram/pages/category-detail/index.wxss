/* Category Detail - Minimalist & Clean Design */
page {
  background-color: #f6f7f9;
  color: #333;
}

/* 移除之前的渐变背景 */
.premium-bg {
  display: none;
}

.content-wrapper {
  padding: 30rpx 30rpx 200rpx;
}

/* 头部设计：纯白卡片，平实稳重 */
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  background: #ffffff;
  padding: 40rpx;
  border-radius: 20rpx;
  /* 极淡的阴影，几乎不可见，只为了区分层级 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

.parent-info-group {
  display: flex;
  align-items: center;
}

.icon-box {
  width: 90rpx;
  height: 90rpx;
  background: #f0f2f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
}

.icon-img {
  width: 56rpx;
  height: 56rpx;
}

.text-box {
  display: flex;
  flex-direction: column;
}

.p-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.p-type {
  font-size: 24rpx;
  color: #999;
}

.stats-label {
  font-size: 22rpx;
  color: #666;
  background: #f0f2f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 列表部分 */
.main-list-section {
  width: 100%;
}

.list-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx 20rpx;
}

.l-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
}

.l-count {
  font-size: 24rpx;
  color: #bbb;
}

.list-container {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden; /* 保证子项的分割线不溢出 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

/* 列表项：回归经典的列表样式 */
.list-item-pro {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5; /* 极细分割线 */
  transition: background-color 0.2s;
}

.list-item-pro:last-child {
  border-bottom: none;
}

.list-item-pro:active {
  background-color: #f9f9f9;
}

.item-left {
  display: flex;
  align-items: center;
}

/* 更低调的指示点 */
.dot-indicator {
  width: 8rpx;
  height: 8rpx;
  background: #ddd; /* 默认灰色 */
  border-radius: 50%;
  margin-right: 24rpx;
}

/* 只有选中或激活时才用绿色，但这只是展示，用实心圆点即可 */
.list-item-pro .name {
  font-size: 30rpx;
  color: #333;
  font-weight: 400; /* 不加粗，更清爽 */
}

.item-right {
  display: flex;
  align-items: center;
}

.use-count {
  font-size: 22rpx;
  color: #ccc;
  margin-right: 20rpx;
  display: none; /* 简洁模式下隐藏这个不太重要的信息 */
}

.del-circle {
  width: 44rpx;
  height: 44rpx;
  /* 去掉红色背景，改为简单的灰色图标，减少视觉干扰 */
  background: transparent; 
  color: #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 50%;
}

.del-circle:active {
  background: #f0f0f0;
  color: #999;
}

/* 底部输入框：实体悬浮 */
.float-input-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  z-index: 100;
  background: transparent; /* 透出背景 */
}

.glass-capsule {
  background: #ffffff; /* 纯白实体 */
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  padding: 0 10rpx 0 40rpx;
  /* 柔和的实体投影，产生悬浮感 */
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08); 
  border: none;
}

.capsule-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #333;
}

.ph-style {
  color: #ccc;
}

.capsule-btn {
  width: 140rpx;
  height: 80rpx;
  background: #333; /* 黑色按钮，极致简洁 */
  color: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  transition: opacity 0.2s;
}

.capsule-btn:active {
  opacity: 0.8;
}

/* 空状态 */
.empty-placeholder {
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  filter: grayscale(100%); /* 灰色图标 */
  opacity: 0.3;
}

.empty-placeholder text {
  font-size: 26rpx;
  color: #ccc;
}

/* 子分类图标 */
.sub-icon-box {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.sub-icon-img {
  width: 40rpx;
  height: 40rpx;
}

/* 底部按钮样式 */
.capsule-placeholder {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* ======== 弹窗 ======== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  animation: fadeIn 0.2s forwards;
}

@keyframes fadeIn { to { opacity: 1; } }

.modal-content {
  width: 620rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  transform: scale(0.9);
  animation: scaleUp 0.2s 0.1s forwards;
}

@keyframes scaleUp { to { transform: scale(1); } }

.modal-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 40rpx;
}

.input-form { margin-bottom: 36rpx; }
.input-row { margin-bottom: 28rpx; }

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn.cancel { background: #f5f6f7; color: #666; }
.btn.confirm { background: #07c160; color: #fff; font-weight: 600; }
.btn.confirm:active { background: #06ad56; }

/* ======== 图标选择器 ======== */
.selected-icon-row { display: flex; align-items: center; }

.selected-icon-box {
  width: 72rpx;
  height: 72rpx;
  background: #f0fdf4;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.selected-icon-img { width: 44rpx; height: 44rpx; }
.selected-icon-placeholder { font-size: 32rpx; color: #ccc; }
.selected-icon-hint { font-size: 24rpx; color: #999; }

.icon-picker { margin-top: 12rpx; }

.picker-tabs {
  display: flex;
  margin-bottom: 16rpx;
  background: #f5f6f7;
  border-radius: 12rpx;
  padding: 4rpx;
}

.picker-tab {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.picker-tab.active {
  background: #fff;
  color: #333;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 分组横向 Tab */
.icon-group-tabs {
  white-space: nowrap;
  margin-bottom: 14rpx;
  padding: 4rpx 0;
}
.icon-group-tab {
  display: inline-block;
  font-size: 24rpx;
  color: #888;
  padding: 10rpx 22rpx;
  margin-right: 12rpx;
  background: #f5f6f7;
  border-radius: 30rpx;
  transition: all 0.2s;
}
.icon-group-tab.active {
  background: #07c160;
  color: #fff;
  font-weight: 600;
}

.icon-grid-scroll { max-height: 320rpx; }
.icon-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }

.icon-grid-item {
  width: 72rpx;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.15s;
}

.icon-grid-item.active {
  border-color: #07c160;
  background: #f0fdf4;
}

.icon-grid-item:active { transform: scale(0.92); }
.icon-grid-img { width: 40rpx; height: 40rpx; }

.upload-item {
  background: #fff;
  border: 3rpx dashed #ccc;
}

.upload-plus { font-size: 36rpx; color: #999; font-weight: 300; }

.icon-empty-hint {
  width: 100%;
  text-align: center;
  padding: 24rpx 0 8rpx;
  font-size: 24rpx;
  color: #bbb;
}
