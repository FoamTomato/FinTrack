  <wxs module="utils">
    var includes = function(list, id) {
      if (!list) return false;
      for (var i = 0; i < list.length; i++) {
        if (list[i] === id) return true;
      }
      return false;
    };
    module.exports = { includes: includes };
  </wxs>

  <!-- 顶部渐变背景氛围感 -->
  <view class="premium-bg"></view>

  <view class="content-wrapper">
    <!-- 头部 -->
    <view class="header-section">
      <view class="parent-info-group">
        <view class="icon-box">
          <image wx:if="{{category.iconUrl}}" class="icon-img" src="{{category.iconUrl}}" mode="aspectFit"></image>
          <text wx:else>{{category.icon || '🏷️'}}</text>
        </view>
        <view class="text-box">
          <text class="p-name">{{category.name}}</text>
          <text class="p-type">{{category.type == 1 ? '收入' : '支出'}}账户</text>
        </view>
      </view>
      <view class="header-action" bindtap="onToggleBatchMode">
        <text class="stats-label">{{batchMode ? '完成' : '批量'}}</text>
      </view>
    </view>

    <!-- 子分类列表 -->
    <view class="main-list-section">
      <view class="list-head">
        <text class="l-title">下属明细</text>
        <text class="l-count">{{subCategories.length}} 个子项</text>
      </view>

      <view class="list-container {{subCategories.length > 0 ? 'has-data' : ''}}">
        <block wx:if="{{subCategories.length > 0}}">
          <view class="list-item-pro {{utils.includes(selectedIds, item.id) ? 'selected' : ''}} {{item.is_enabled == 0 ? 'disabled' : ''}}"
                wx:for="{{subCategories}}" wx:key="id"
                bindtap="{{batchMode ? 'onToggleSelect' : ''}}"
                data-id="{{item.id}}">
            <view class="item-left">
              <view wx:if="{{batchMode}}" class="checkbox {{utils.includes(selectedIds, item.id) ? 'checked' : ''}}"></view>
              <view class="sub-icon-box">
                <image wx:if="{{item.iconUrl}}" class="sub-icon-img" src="{{item.iconUrl}}" mode="aspectFit"></image>
                <view wx:else class="dot-indicator"></view>
              </view>
              <text class="name">{{item.name}}</text>
              <view wx:if="{{item.is_enabled == 0}}" class="disabled-tag">已禁用</view>
            </view>
            <view class="item-right" wx:if="{{!batchMode}}">
              <view class="enable-switch {{item.is_enabled == 1 ? 'on' : 'off'}}"
                    catchtap="onToggleEnabled" data-id="{{item.id}}" data-enabled="{{item.is_enabled == 1}}">
                <view class="switch-knob"></view>
              </view>
              <view wx:if="{{item.is_default != 1}}" class="del-circle" catchtap="onDeleteSubCategory" data-id="{{item.id}}">
                <text class="icon-x">✕</text>
              </view>
            </view>
          </view>
        </block>

        <view class="empty-placeholder" wx:else>
          <view class="empty-icon">📂</view>
          <text>还没有子分类，立即在下方添加</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 批量操作栏 -->
  <view class="batch-bar" wx:if="{{batchMode}}">
    <text class="batch-count">已选 {{selectedIds.length}} 项</text>
    <view class="batch-actions">
      <view class="batch-btn enable" bindtap="onBatchEnable">批量启用</view>
      <view class="batch-btn disable" bindtap="onBatchDisable">批量禁用</view>
    </view>
  </view>

  <!-- 底部添加按钮 -->
  <view class="float-input-box" wx:if="{{!batchMode}}">
    <view class="glass-capsule" bindtap="onShowAddModal">
      <text class="capsule-placeholder">+ 添加子分类</text>
    </view>
  </view>

  <!-- 添加子分类弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}">
    <view class="modal-content">
      <view class="modal-title">添加子分类</view>
      <view class="input-form">
        <!-- 名称 -->
        <view class="input-row">
          <text class="input-label">名称</text>
          <input class="modal-input" placeholder="如：早午餐、零食..." bindinput="onInputSubName" value="{{newSubName}}" focus="{{showModal}}"/>
        </view>

        <!-- 已选图标预览 -->
        <view class="input-row">
          <text class="input-label">图标</text>
          <view class="selected-icon-row">
            <view class="selected-icon-box">
              <image wx:if="{{newSubIconUrl}}" class="selected-icon-img" src="{{newSubIconUrl}}" mode="aspectFit"></image>
              <text wx:else class="selected-icon-placeholder">?</text>
            </view>
            <text class="selected-icon-hint">{{newSubIconUrl ? '点击下方更换' : '可选，默认继承父级'}}</text>
          </view>
        </view>

        <!-- 图标选择 Tab -->
        <view class="icon-picker">
          <view class="picker-tabs">
            <view class="picker-tab {{iconTab === 'preset' ? 'active' : ''}}" bindtap="onSwitchIconTab" data-tab="preset">系统图标</view>
            <view class="picker-tab {{iconTab === 'mine' ? 'active' : ''}}" bindtap="onSwitchIconTab" data-tab="mine">我的图标</view>
          </view>

          <!-- 系统图标：分组横向 tab -->
          <scroll-view scroll-x class="icon-group-tabs" wx:if="{{iconTab === 'preset'}}" enable-flex>
            <view class="icon-group-tab {{iconGroupKey === g.key ? 'active' : ''}}"
                  wx:for="{{iconGroups}}" wx:for-item="g" wx:key="key"
                  bindtap="onSwitchIconGroup" data-key="{{g.key}}">
              {{g.label}}
            </view>
          </scroll-view>

          <scroll-view scroll-y class="icon-grid-scroll">
            <view class="icon-grid" wx:if="{{iconTab === 'preset'}}">
              <view class="icon-grid-item {{newSubIcon === item.url ? 'active' : ''}}"
                    wx:for="{{currentGroupIcons}}" wx:key="url"
                    bindtap="onSelectPresetIcon"
                    data-url="{{item.url}}">
                <image class="icon-grid-img" src="{{item.url}}" mode="aspectFit"></image>
              </view>
            </view>

            <view class="icon-grid" wx:if="{{iconTab === 'mine'}}">
              <view class="icon-grid-item {{newSubIcon === item.url ? 'active' : ''}}"
                    wx:for="{{userIcons}}" wx:key="id"
                    bindtap="onSelectUserIcon"
                    data-url="{{item.url}}">
                <image class="icon-grid-img" src="{{item.url}}" mode="aspectFit"></image>
              </view>
              <view class="icon-grid-item upload-item" bindtap="onUploadIcon">
                <text class="upload-plus">+</text>
              </view>
              <view class="icon-empty-hint" wx:if="{{userIcons.length === 0}}">
                <text>点击 + 上传自定义图标</text>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn cancel" bindtap="onHideModal">取消</button>
        <button class="btn confirm" bindtap="onAddSubCategory">确定</button>
      </view>
    </view>
  </view>
