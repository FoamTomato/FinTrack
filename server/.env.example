# 微信小程序配置
WX_APPID=your_wechat_appid_here
WX_SECRET=your_wechat_appsecret_here

# MySQL 数据库配置
MYSQL_HOST=your_mysql_host_here
MYSQL_PORT=3306
MYSQL_USERNAME=your_mysql_username_here
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=your_database_name_here

# 腾讯云 COS 配置（可选）
COS_BUCKET=your_cos_bucket_here
COS_REGION=ap-shanghai

# 服务配置
PORT=80
NODE_ENV=production
